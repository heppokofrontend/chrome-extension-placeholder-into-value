{
  "manifest_version": 3,
  "minimum_chrome_version": "120",
  "background": {
    "service_worker": "/worker.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["/content_scripts.js"]
    }
  ],
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "name": "__MSG_extName__",
  "description": "__MSG_extDesc__",
  "permissions": ["contextMenus", "activeTab"],
  "version": "1.1.0",
  "default_locale": "en"
}
